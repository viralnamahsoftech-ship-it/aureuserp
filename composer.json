{
    "name": "aureuserp/aureuserp",
    "type": "project",
    "description": "Open Source ERP Solution built on Laravel for Small and Medium Enterprises (SMEs) and large-scale enterprises.",
    "keywords": [
        "erp",
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "aureuserp/nativephp-remote": "^0.1.0",
        "barryvdh/laravel-debugbar": "^4.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "bezhansalleh/filament-language-switch": "^4.3",
        "bezhansalleh/filament-shield": "^4.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "flowframe/laravel-trend": "^0.5",
        "guava/filament-icon-picker": "^4.0",
        "knuckleswtf/scribe": "^5.6",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "malzariey/filament-daterangepicker-filter": "^5.0",
        "milon/barcode": "^13.0",
        "nativephp/mobile": "^3.3",
        "spatie/eloquent-sortable": "^5.0",
        "spatie/laravel-query-builder": "^7.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^5.0",
        "laravel/boost": "^2.1",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Webkul\\BusinessMasters\\": "plugins/webkul/business-masters/src/",
            "Webkul\\BusinessMasters\\Database\\Factories\\": "plugins/webkul/business-masters/database/factories/",
            "Webkul\\BusinessMasters\\Database\\Seeders\\": "plugins/webkul/business-masters/database/seeders/",
            "Webkul\\BusinessParty\\": "plugins/webkul/business-party/src/",
            "Webkul\\BusinessParty\\Database\\Factories\\": "plugins/webkul/business-party/database/factories/",
            "Webkul\\BusinessParty\\Database\\Seeders\\": "plugins/webkul/business-party/database/seeders/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "plugins/*/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/aureuserp/aureuserp/issues",
        "forum": "https://forums.aureuserp.com",
        "source": "https://github.com/aureuserp/aureuserp",
        "docs": "https://devdocs.aureuserp.com"
    }
}
